DATABASE_URL=postgresql+psycopg2://CAMBIAR_USUARIO:CAMBIAR_PASSWORD@CAMBIAR_HOST:5432/CAMBIAR_DB
SECRET_KEY=CAMBIAR_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional bootstrap (creates/updates a superadmin on startup).
# For local dev only; don't commit real credentials. The file `.env` is gitignored.
# BOOTSTRAP_SUPERADMIN_USERNAME=CAMBIAR_SUPERADMIN_USER
# BOOTSTRAP_SUPERADMIN_PASSWORD=CAMBIAR_SUPERADMIN_PASSWORD

# Optional (used by docker-compose.yml defaults)
# POSTGRES_DB=CAMBIAR_DB
# POSTGRES_USER=CAMBIAR_USER
# POSTGRES_PASSWORD=CAMBIAR_PASSWORD
